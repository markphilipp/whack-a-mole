# whack-a-mole config — TEMPLATE.
#
# Copy to config.yaml on setup (install.sh does this for you) and fill in your
# values. config.yaml is gitignored; this .example file is the committed template.
#
#   cp config.yaml.example config.yaml
#
# The daemon reads config.yaml in place (via the ~/.claude/whack-a-mole symlink
# install.sh creates). Edit it directly.

poll_interval_seconds: 180

# Modes:
#   alpha — detect only; log would-dispatch; no Claude session spawned.
#   beta  — full dispatch, Claude runs and edits files in the worktree,
#           but NO `git push` and NO `gh api` reply. Flip to `live` once
#           you've eyeballed a few runs.
#   live  — full end-to-end. Pushes commits and posts replies.
mode: alpha

# Model routing for spawned Claude sessions.
# Default is cost-oriented; escalation is used for "complex" trigger signals and
# optionally as a fallback if the default-model run exits non-zero.
models:
  default: sonnet
  escalation: opus
  intelligent_switching: true
  escalate_on_failure: true

# Only act on PRs you authored. Set to false to also handle teammates' / bots'
# PRs (risky — they'll get auto-replies signed as you).
only_my_prs: true
my_github_login: your-github-username

# Git identity for the commits whack-a-mole makes in PR worktrees.
#   git_user        — commit author name (applies to all repos).
#   git_user_email  — default author email; any repo may override it with its
#                     own `git_user_email` below (e.g. work vs. personal).
# Set worktree-locally, so your global git config is never touched.
git_user: your-github-username
git_user_email: you@personal.example

# Loop caps — separate because intent differs.
#   bugbot: tight cap; a loop usually means a bad auto-fix.
#   ci:     intentional loop; cap exists only to bound runaway cases.
max_bugbot_fixes_per_pr: 2
max_ci_fix_attempts: 10

# Repos to watch. Each must already be cloned locally.
repos:
  - github: your-org/your-repo
    local: /absolute/path/to/your/clone
    worktree_root: .claude/worktrees
    # Optional per-repo email override; omit to use the top-level git_user_email.
    git_user_email: you@work.example
    # Optional per-repo worktree provisioning. A fresh git worktree shares .git
    # but gets a clean checkout, so gitignored deps (.venv, node_modules) are
    # absent and quick_checks would fail. These run once, in $WT_PATH, before the
    # spawned Claude starts — as a single shell sequence (so `source` persists to
    # the next line). Any non-zero exit aborts the dispatch and tears the
    # worktree down. Omit the key for repos that need no setup.
    worktree_setup:
      - python3.14 -m venv .venv
      - source .venv/bin/activate
      - poetry install --no-root --with pyright --with dev
    quick_checks:
      - ruff check {changed}
      - ruff format --check {changed}
      - basedpyright {changed}

  - github: your-org/another-repo
    local: /absolute/path/to/another/clone
    worktree_root: .claude/worktrees
    worktree_setup:
      - pnpm i
    quick_checks:
      - pnpm lint {changed}
      - pnpm format:check {changed}
      - pnpm typecheck

triggers:
  bugbot_comments: true
  ci_failures: true
